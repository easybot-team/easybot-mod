{
  "token": "YOUR_TOKEN_HERE",
  "ws": "ws://127.0.0.1:26990/bridge",
  "debug": false,
  "ignoreError": false,
  "message": {
    "bindStart": "[!] 绑定开始,请加群12345678输入: \"绑定 #code\" 进行绑定, 请在#time完成绑定!",
    "bindSuccess": "§f[§a!§f] 绑定§f §a#account §f(§a#name§f) 成功!",
    "bindFail": "",
    "syncSuccess": ""
  },
  "command": {
    "allowBind": true
  },
  "skipOptions": {
    "skipJoin": false,
    "skipQuit": false,
    "skipChat": false,
    "skipDeath": false
  },
  "geyser": {
    "ignorePrefix": false,
    "useRealUuid": false
  },
  "event": {
    "enableSuccessEvent": false,
    "bindSuccess": [
      "say 玩家$player绑定成功,Id=$account,账号名字=$name"
    ]
  }
}